      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Core Target Health",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "refId": "A",
          "expr": "up{job=~\"prometheus|grafana|alertmanager|loki|tempo|pyroscope|otelcol-contrib\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {},
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 2,
      "title": "Scrape Samples",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "refId": "A",
          "expr": "sum by (job) (scrape_samples_scraped{job=~\"prometheus|grafana|alertmanager|loki|tempo|pyroscope|otelcol-contrib\"})",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {},
          "unit": "short"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "title": "Process CPU",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "refId": "A",
          "expr": "sum by (job) (rate(process_cpu_seconds_total{job=~\"prometheus|grafana|alertmanager|loki|tempo|pyroscope|otelcol-contrib\"}[5m]))",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {},
          "unit": "cores"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "title": "Resident Memory",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "refId": "A",
          "expr": "sum by (job) (process_resident_memory_bytes{job=~\"prometheus|grafana|alertmanager|loki|tempo|pyroscope|otelcol-contrib\"})",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {},
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "refId": "A",
          "expr": "sum by (job) (rate({__name__=~\"prometheus_http_requests_total|grafana_http_request_duration_seconds_count|loki_request_duration_seconds_count|tempo_request_duration_seconds_count|pyroscope_request_duration_seconds_count\"}[5m]))",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {},
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "title": "HTTP 5xx / Error Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "refId": "A",
          "expr": "sum by (job) (rate({__name__=~\"prometheus_http_requests_total|grafana_http_request_duration_seconds_count|loki_request_duration_seconds_count|tempo_request_duration_seconds_count|pyroscope_request_duration_seconds_count\", status_code=~\"5..|500\", code!=\"\"}[5m])) or sum by (job) (rate({__name__=~\"prometheus_http_requests_total|grafana_http_request_duration_seconds_count|loki_request_duration_seconds_count|tempo_request_duration_seconds_count|pyroscope_request_duration_seconds_count\", status=~\"5..|500\"}[5m]))",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {},
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 7,
      "title": "Recent Stack Logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "refId": "A",
          "expr": "{docker_compose_project=\"home-monitoring\"}",
          "queryType": "range",
          "maxLines": 100
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    }
  ],
