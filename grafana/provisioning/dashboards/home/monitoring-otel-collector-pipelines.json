{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Accepted Telemetry",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "refId": "A",
          "expr": "sum by (receiver, data_type) (rate(otelcol_receiver_accepted_metric_points_total[5m])) or sum by (receiver, data_type) (rate(otelcol_receiver_accepted_log_records_total[5m])) or sum by (receiver, data_type) (rate(otelcol_receiver_accepted_spans_total[5m])) or sum by (receiver, data_type) (rate(otelcol_receiver_accepted_profiles_total[5m]))",
          "legendFormat": "{{receiver}} {{data_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {},
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 2,
      "title": "Refused / Failed Telemetry",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "refId": "A",
          "expr": "sum by (receiver, data_type) (rate(otelcol_receiver_refused_metric_points_total[5m])) or sum by (receiver, data_type) (rate(otelcol_receiver_refused_log_records_total[5m])) or sum by (receiver, data_type) (rate(otelcol_receiver_refused_spans_total[5m])) or sum by (receiver, data_type) (rate(otelcol_receiver_refused_profiles_total[5m])) or sum by (receiver) (rate(otelcol_receiver_failed_log_records_total[5m]))",
          "legendFormat": "{{receiver}} {{data_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {},
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "title": "Exporter Sent",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "refId": "A",
          "expr": "sum by (exporter, data_type) (rate(otelcol_exporter_sent_metric_points_total[5m])) or sum by (exporter, data_type) (rate(otelcol_exporter_sent_log_records_total[5m])) or sum by (exporter, data_type) (rate(otelcol_exporter_sent_spans_total[5m])) or sum by (exporter, data_type) (rate(otelcol_exporter_sent_profiles_total[5m]))",
          "legendFormat": "{{exporter}} {{data_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {},
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "title": "Exporter Failed",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "refId": "A",
          "expr": "sum by (exporter, data_type) (rate(otelcol_exporter_send_failed_metric_points_total[5m])) or sum by (exporter, data_type) (rate(otelcol_exporter_send_failed_log_records_total[5m])) or sum by (exporter, data_type) (rate(otelcol_exporter_send_failed_spans_total[5m])) or sum by (exporter, data_type) (rate(otelcol_exporter_send_failed_profiles_total[5m]))",
          "legendFormat": "{{exporter}} {{data_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {},
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "title": "Exporter Queue Fill",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "refId": "A",
          "expr": "sum by (exporter, data_type) (otelcol_exporter_queue_size) / sum by (exporter, data_type) (otelcol_exporter_queue_capacity)",
          "legendFormat": "{{exporter}} {{data_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {},
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "title": "Profile Scraper Errors",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "refId": "A",
          "expr": "sum by (receiver) (rate(otelcol_scraper_errored_profile_records_total[5m]))",
          "legendFormat": "{{receiver}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {},
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 7,
      "title": "Collector CPU / Memory",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "refId": "A",
          "expr": "rate(otelcol_process_cpu_seconds_total[5m])",
          "legendFormat": "cpu"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "refId": "B",
          "expr": "otelcol_process_memory_rss_bytes",
          "legendFormat": "rss"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {},
          "unit": "short"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 8,
      "title": "Collector Logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "refId": "A",
          "expr": "{docker_compose_project=\"home-monitoring\", docker_compose_service=\"otel-collector\"}",
          "queryType": "range",
          "maxLines": 100
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
